# --- OS junk ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db

# --- Python build artifacts ---
__pycache__/
*.py[cod]
*$py.class
*.pyd
*.so
*.dylib

# --- Virtual environments & tooling ---
.venv/
venv/
env/
.python-version        # pyenv
pip-wheel-metadata/

# --- Packages / builds / dist ---
build/
dist/
*.egg-info/
.eggs/

# --- Notebooks ---
.ipynb_checkpoints/

# --- Test / coverage caches ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# --- Linters / type checkers ---
.mypy_cache/
.ruff_cache/
.pytype/
.pyright/

# --- Editors / IDEs ---
.vscode/
.idea/
*.code-workspace

# --- Logs & temp ---
*.log
*.tmp
*.temp
*.swp
*.swo

# --- Environment & secrets ---
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.csr
*.crt

# --- Config overrides (keep committed defaults only) ---
config/*local*.toml
config/*secrets*.*
config/*.override.*

# --- Data zones (don’t version large/ephemeral data) ---
data/external/**
data/raw/**
data/interim/**
data/processed/**
# But DO keep canonical seeds that ship with the repo:
!data/seed/**
# Allow placeholder keepers so folders exist in git:
!data/**/.gitkeep

# --- ETL scratch / outputs (optional; uncomment if you generate these) ---
# notebooks/.ipynb_checkpoints/
# outputs/**
# reports/**
# tmp/**

# --- Node (only if you ever add a small UI here) ---
node_modules/
npm-debug.log*
yarn-error.log*

# --- Docker (optional) ---
# .docker/
# *.tar
